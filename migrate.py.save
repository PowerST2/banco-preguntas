from __future__ import annotations

import hashlib
import os
from pathlib import Path

import psycopg
from dotenv import load_dotenv
from sshtunnel import SSHTunnelForwarder


ROOT = Path(__file__).resolve().parent
MIGRATIONS_DIR = ROOT / "migrations"


def sha256_text(text: str) -> str:
    return hashlib.sha256(text.encode("utf-8")).hexdigest()


def get_env(name: str, default: str | None = None, required: bool = False) -> str:
    value = os.getenv(name, default)
    if required and (value is None or value == ""):
        raise RuntimeError(f"Falta variable requerida: {name}")
    return value or ""


def ensure_migrations_table(conn: psycopg.Connection) -> None:
    with conn.cursor() as cur:
        cur.execute(
            """
            CREATE TABLE IF NOT EXISTS schema_migrations (
                id BIGSERIAL PRIMARY KEY,
                filename TEXT NOT NULL UNIQUE,
                checksum TEXT NOT NULL,
                executed_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
            );
            """
        )
    conn.commit()


def applied_map(conn: psycopg.Connection) -> dict[str, str]:
    with conn.cursor() as cur:
        cur.execute("SELECT filename, checksum FROM schema_migrations ORDER BY id;")
        rows = cur.fetchall()
    return {filename: checksum for filename, checksum in rows}


def migration_files() -> list[Path]:
    files = sorted(MIGRATIONS_DIR.glob("*.sql"))
    return [f for f in files if f.is_file()]


def apply_migration(conn: psycopg.Connection, file_path: Path) -> None:
    sql = file_path.read_text(encoding="utf-8")
    checksum = sha256_text(sql)

    with conn.cursor() as cur:
        cur.execute(sql)
        cur.execute(
            "INSERT INTO schema_migrations (filename, checksum) VALUES (%s, %s)",
            (file_path.name, checksum),
        )
    conn.commit()


def run(conn: psycopg.Connection) -> None:
    ensure_migrations_table(conn)
    already = applied_map(conn)

    pending = migration_files()
    if not pending:
        print("No hay archivos de migración en ./migrations")
        return

    for f in pending:
        sql = f.read_text(encoding="utf-8")
        checksum = sha256_text(sql)

        if f.name in already:
            if already[f.name] != checksum:
                raise RuntimeError(
                    f"La migración {f.name} ya fue aplicada pero su contenido cambió. "
                    "Crea una nueva migración en lugar de editarla."
env/bin/activate ) print(f"[SKIP] {f.name}") continue python migrate.py 
