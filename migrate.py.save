def connect_direct() -> psycopg.Connection:
    db_host = get_env("DB_HOST", required=True)
    db_port = int(get_env("DB_PORT", "5432"))
    db_name = get_env("DB_DATABASE", required=True)
    db_user = get_env("DB_USERNAME", required=True)
    db_password = get_env("DB_PASSWORD", required=True)

    return psycopg.connect(
        host=db_host,
        port=db_port,
        dbname=db_name,
        user=db_user,
        password=db_password,
        connect_timeout=10,
    )


def main() -> None:
    load_dotenv(ROOT / ".env")

    use_ssh = get_env("USE_SSH_TUNNEL", "false").lower() == "true"

    if not use_ssh:
        with connect_direct() as conn:
            run(conn)
        return

    ssh_host = get_env("SSH_HOST", required=True)
    ssh_port = int(get_env("SSH_PORT", "22"))
    ssh_username = get_env("SSH_USERNAME", required=True)
    ssh_private_key = get_env("SSH_PRIVATE_KEY", required=True)
    ssh_private_key_password = get_env("SSH_PRIVATE_KEY_PASSWORD", None, required=False) or None

    remote_db_host = get_env("REMOTE_DB_HOST", "127.0.0.1")
    remote_db_port = int(get_env("REMOTE_DB_PORT", "5432"))

    db_name = get_env("DB_DATABASE", required=True)
    db_user = get_env("DB_USERNAME", required=True)
    db_password = get_env("DB_PASSWORD", required=True)

    tunnel = SSHTunnelForwarder(
        (ssh_host, ssh_port),
        ssh_username=ssh_username,
        ssh_pkey=ssh_private_key,
        ssh_private_key_password=ssh_private_key_password,
        remote_bind_address=(remote_db_host, remote_db_port),
    )

    try:
        tunnel.start()
        with psycopg.connect(
            host="127.0.0.1",
            port=tunnel.local_bind_port,
            dbname=db_name,
            user=db_user,
            password=db_password,
            connect_timeout=10,
        ) as conn:
            run(conn)
    finally:
        tunnel.stop()


if __name__ == "__main__":
    main()
